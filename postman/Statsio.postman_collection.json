    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Login success is true\", function () {\r",
                  "    pm.expect(res.success).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token exists\", function () {\r",
                  "    pm.expect(res.data.token).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "if(res.token) {\r",
                  "    pm.environment.set(\"token\", res.data.token);\r",
                  "    pm.environment.set(\"token_type\", res.data.type);\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept-Language",
                "value": "{{language}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login?email={{email}}&password={{password}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ],
              "query": [
                {
                  "key": "email",
                  "value": "{{email}}"
                },
                {
                  "key": "password",
                  "value": "{{password}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let res = pm.response.json();\r",
                  "\r",
                  "\r",
                  "// ✅ Tests\r",
                  "pm.test(\"Status code is 200 or 201\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Register success is true\", function () {\r",
                  "    pm.expect(res.success).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token exists\", function () {\r",
                  "    pm.expect(res.data?.token).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User created\", function () {\r",
                  "    pm.expect(res.data?.user?.id).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "if (res.success && res.data?.token) {\r",
                  "    pm.environment.set(\"token\", res.data.token);\r",
                  "    pm.environment.set(\"token_type\", res.data.type);\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
