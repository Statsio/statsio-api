APP_NAME=Statsio_API
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:your-app-key-here
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_URL=http://localhost:8080
GOOGLE_CLIENT_ID=
SANCTUM_EXPIRATION=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=statsio
DB_USERNAME=statsio
DB_PASSWORD=statsio

STATS_DATA_MAX_SNAPSHOT_ROWS=50000
STATS_DATA_MAX_QUERY_ROWS=10000

POSTGRES_DB=statsio
POSTGRES_USER=statsio
POSTGRES_PASSWORD=statsio

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@statsio.fr
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2
R2_ENDPOINT=https://b8806b9c9f69ebcc9353a1cb84784127.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DATASETS_BUCKET=statsio-datasets
R2_MEDIA_BUCKET=statsio-media
R2_MEDIA_URL=

VITE_APP_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:8080,127.0.0.1:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173
GOOGLE_CLIENT_ID=

# File upload settings
UPLOAD_MAX_FILESIZE=15M
POST_MAX_SIZE=15M
