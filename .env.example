APP_NAME=Statsio_API
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:your-app-key-here
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_URL=http://localhost:8080
GOOGLE_CLIENT_ID=
SANCTUM_EXPIRATION=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=statsio
DB_USERNAME=statsio
DB_PASSWORD=statsio

STATS_DATA_MAX_SNAPSHOT_ROWS=50000
STATS_DATA_MAX_QUERY_ROWS=10000

# API publique BDPM (page Médicaments de MédiStats)
MEDICAMENTS_API_BASE_URL=https://medicaments-api.giygas.dev

# API publique WHO GHO OData (pages Maladies + Pays de MédiStats)
WHO_GHO_API_BASE_URL=https://ghoapi.azureedge.net/api

# API ICD-11 (icd.who.int/icdapi) — classification des maladies (page Maladies de MédiStats).
# Credentials à créer sur https://icd.who.int/icdapi (compte gratuit) : ne jamais committer les
# vraies valeurs, uniquement dans le .env local.
ICD11_API_BASE_URL=https://id.who.int
ICD11_TOKEN_URL=https://icdaccessmanagement.who.int/connect/token
ICD11_CLIENT_ID=
ICD11_CLIENT_SECRET=
ICD11_RELEASE_ID=latest

# API UMLS/UTS (uts-ws.nlm.nih.gov) — enrichissement optionnel symptômes/facteurs de risque.
# Clé gratuite via https://uts.nlm.nih.gov/uts/signup-login. Laisser vide pour désactiver
# proprement cette section (dégradation gracieuse, pas d'erreur).
UMLS_API_BASE_URL=https://uts-ws.nlm.nih.gov/rest
UMLS_API_KEY=

POSTGRES_DB=statsio
POSTGRES_USER=statsio
POSTGRES_PASSWORD=statsio

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Brevo SMTP relay (smtp-relay.brevo.com:587)
# Compte Brevo > SMTP & API > SMTP > Générer une clé SMTP
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login@example.com
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_FROM_ADDRESS=noreply@statsio.fr
MAIL_FROM_NAME="${APP_NAME}"
BREVO_API_KEY=

# Cloudflare R2
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DATASETS_BUCKET=statsio-datasets
R2_MEDIA_BUCKET=statsio-media
R2_MEDIA_URL=

# Disque de stockage (local/public en dev, r2-datasets/r2-media en prod)
DATASETS_DISK=local
MEDIA_DISK=public

VITE_APP_NAME="${APP_NAME}"

ADMIN_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000,localhost:8080,127.0.0.1:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
GOOGLE_CLIENT_ID=

# File upload settings
UPLOAD_MAX_FILESIZE=15M
POST_MAX_SIZE=15M

# OpenObserve (logs/observabilité, service docker-compose "openobserve")
ZO_ROOT_USER_EMAIL=admin@statsio.local
ZO_ROOT_USER_PASSWORD=
